# Generated by `devspec ci init`. Sourced from the pipeline/github fragment.
# To customize, edit src/packs/pipeline/github/templates/workflow.yml.tpl and rerun.
# The install step needs your config (see comment block in the `devspec` job).
name: ci

on:
  pull_request:
  push:
    branches: [main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  security:
    name: security
    runs-on: ubuntu-24.04
    permissions:
      contents: read
      pull-requests: read
      security-events: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Secret scan (gitleaks)
        uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Dependency review
        if: github.event_name == 'pull_request'
        uses: actions/dependency-review-action@v4
        with:
          fail-on-severity: high
          comment-summary-in-pr: on-failure

  quality:
    name: quality
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build dev image
        uses: docker/build-push-action@v6
        with:
          context: .
          load: true
          tags: devspec-dev:ci
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Format check
        run: docker compose run --rm dev sh -c "$DEVSPEC_CMD"
        env:
          DEVSPEC_CMD: |-
            {{ backend.commands.format_check }}

      - name: Lint (warnings as errors)
        run: docker compose run --rm dev sh -c "$DEVSPEC_CMD"
        env:
          DEVSPEC_CMD: |-
            {{ backend.commands.lint }}

      - name: Typecheck
        run: docker compose run --rm dev sh -c "$DEVSPEC_CMD"
        env:
          DEVSPEC_CMD: |-
            {{ backend.commands.typecheck }}

  test-unit:
    name: test-unit
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build dev image
        uses: docker/build-push-action@v6
        with:
          context: .
          load: true
          tags: devspec-dev:ci
          cache-from: type=gha

      - name: Run unit tests
        run: docker compose run --rm dev sh -c "$DEVSPEC_CMD"
        env:
          DEVSPEC_CMD: |-
            {{ backend.commands.test_unit }}

  test-integration:
    name: test-integration
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build dev image
        uses: docker/build-push-action@v6
        with:
          context: .
          load: true
          tags: devspec-dev:ci
          cache-from: type=gha

      - name: Run integration tests
        run: docker compose run --rm dev sh -c "$DEVSPEC_CMD"
        env:
          DEVSPEC_CMD: |-
            {{ backend.commands.test_integration }}

  test-e2e:
    name: test-e2e
    runs-on: ubuntu-24.04
    if: {{ has_frontend }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Install Playwright browsers
        run: npx playwright install --with-deps chromium

      - name: Build app
        run: "{{ frontend.commands.build }}"

      - name: Run E2E tests
        run: "{{ frontend.commands.test_e2e }}"

      - name: Upload Playwright report on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report
          path: playwright-report/
          retention-days: 7

  devspec:
    name: devspec
    runs-on: ubuntu-24.04
    permissions:
      contents: read
      security-events: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-node@v4
        with:
          node-version: '22'

      # ─────────────────────────────────────────────────────────────────────
      # Install devspec. Defaults to the published npm package. Alternatives
      # if you need a pinned fork or unreleased build:
      #   npm install -g github:YOUR_ORG/devspec#main
      #   git clone --depth 1 https://github.com/YOUR_ORG/devspec /tmp/devspec \
      #     && cd /tmp/devspec && npm ci && npm run build && npm link
      # ─────────────────────────────────────────────────────────────────────
      - name: Install devspec
        run: npm install -g devspec-cli

      - name: devspec doctor
        run: devspec doctor

      - name: devspec check
        run: devspec check

      - name: Coherence per active change
        run: |
          set -e
          shopt -s nullglob
          mkdir -p .devspec-sarif
          had_drift=0
          for dir in .devspec/projects/*/; do
            slug="$(basename "$dir")"
            echo "::group::coherence $slug"
            if ! devspec coherence "$slug" --json --block-only --sarif ".devspec-sarif/$slug.sarif" > /dev/null; then
              echo "::error title=DevSpec drift in $slug::Run \`devspec coherence $slug\` locally to see details."
              had_drift=1
            fi
            echo "::endgroup::"
          done
          if [ "$had_drift" -ne 0 ]; then
            exit 1
          fi

      # Surfaces coherence findings as code-scanning annotations on the PR.
      # Requires GitHub Advanced Security on private repos (free on public),
      # hence continue-on-error — the gate above already failed the job on
      # blocking drift; this step is visibility, not enforcement.
      - name: Upload coherence findings to code scanning
        if: always()
        continue-on-error: true
        uses: github/codeql-action/upload-sarif@v3
        with:
          sarif_file: .devspec-sarif
          category: devspec-coherence

      - name: Workspace phase (informational)
        if: always()
        run: devspec phase || true
